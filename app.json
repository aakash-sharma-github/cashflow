{
  "expo": {
    "name": "CashFlow",
    "slug": "cashflow",
    "version": "4.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B5FED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cashflow.cashflow",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used for secure authentication",
        "NSUserNotificationUsageDescription": "We send notifications when you receive book invitations."
      },
      "jsEngine": "hermes"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B5FED"
      },
      "package": "com.cashflow.cashflow",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "cashflow"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 1,
      "jsEngine": "hermes"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#5B5FED",
      "androidMode": "default"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "cashflow",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#5B5FED"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5B5FED",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": false,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2dd5e903-ee74-4052-aa22-b8e1751a1ebf"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2dd5e903-ee74-4052-aa22-b8e1751a1ebf",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "assets/*",
      "assets/fonts/*"
    ],
    "owner": "aakash-expo"
  }
}