# Copy this to .env and fill in your values
# These are exposed to the client (safe - use anon/public keys only)

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key-here>
EDGE_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1/cashflow-invite

# For Supabase Edge Function (set in Supabase dashboard → Project Settings → Edge Functions)
RESEND_API_KEY=<your-resend-api-key-here>
APP_URL=cashflow://auth/callback

# For EAS Update (set in Expo dashboard → Project → Build & Submit → EAS Update)
EXPO_PUBLIC_EAS_PROJECT_ID=<your-eas-project-id-here>